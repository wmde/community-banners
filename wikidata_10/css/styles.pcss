$border-color: #006699;
$background-color: #ffffff;
$text-color: #000000;
$button-background-color: #006699;
$button-background-color-green: #339966;
$font-family: 'Montserrat', 'Arial', 'Verdana', sans-serif;

.skin-minerva {
	.banner-container {
		padding-top: 10px;

		@media ( min-width: 1000px ) {
			max-width: none;
		}
	}
}

/* stylelint-disable-next-line */
#WMDE-Banner-Container * {
	box-sizing: border-box;
}

/* stylelint-disable-next-line */
#WMDE-Banner-Container .WMDE-banner {
	position: relative;
	border: 3px solid $border-color;
	font-family: $font-family;
	text-align: left;

	img {
		width: 100%;
		height: auto;
	}

	svg {
		display: block;
	}

	&-close-button {
		position: absolute;
		top: 0;
		right: 0;
		height: 30px;
		width: 30px;
		padding: 8px;

		&:hover,
		&:focus {
			opacity: 0.8;
		}
	}

	&-wrapper {
		@media ( min-width: 899px ) {
			display: flex;
		}
	}

	&-content {
		@media ( min-width: 899px ) {
			flex: 1 auto;
			display: flex;
		}

		&-left {
			display: flex;
			@media ( min-width: 1099px ) {
				flex: 1 100%;
				align-items: center;
				flex-direction: column;
				justify-content: center;
			}
		}

		&-right {
			display: flex;
			align-items: center;
			justify-content: center;

			@media ( min-width: 1099px ) {
				padding-right: 8px;
			}
		}
	}

	&-title,
	&-button {
		font-weight: bold;
	}

	&-inline-image {
		flex: 0 25%;
		min-width: 80px;
		max-width: 250px;
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: 8px 0 8px 8px;

		>div {
			flex-shrink: 0;
		}

		@media ( min-width: 899px ) {
			display: none;
		}
	}

	&-copy {
		flex: 1 auto;
		display: flex;
		justify-content: center;
		align-items: center;
		font-size: 10px;
		padding: 8px 16px;
		line-height: 1.5;

		@media ( min-width: 499px ) {
			font-size: 14px;
		}

		@media ( min-width: 599px ) {
			font-size: 18px;
		}

		@media ( min-width: 699px ) {
			padding: 8px 4px;
		}

		@media ( min-width: 899px ) {
			flex: 0 100%;
			font-size: 13px;
		}

		@media ( min-width: 999px ) {
			padding: 8px 16px;
		}

		@media ( min-width: 1099px ) {
			font-size: 14px;
		}

		@media ( min-width: 1299px ) {
			font-size: 18px;
		}
	}

	&-button {
		font-size: 10px;
		width: 100%;
		text-align: center;
		line-height: 45px;
		white-space: nowrap;
		cursor: pointer;
		transition: transform 500ms ease-in-out;
		color: $background-color;
		font-family: $font-family;

		&-schedule {
			background: $button-background-color;
		}

		&-event {
			background: $button-background-color-green;
		}

		&:hover,
		&:focus {
			transform: scale( 1.1 );
			text-decoration: none;
		}

		@media ( min-width: 499px ) {
			line-height: 65px;
			font-size: 14px;
		}

		@media ( min-width: 599px ) {
			font-size: 18px;
		}

		@media ( min-width: 899px ) {
			display: inline-block;
			width: auto;
			margin: 0 8px;
			padding: 0 20px;
			line-height: 36px;
			font-size: 12px;
		}

		@media ( min-width: 1099px ) {
			font-size: 14px;
		}
	}

	&-image {
		display: none;
		flex: 0 0 70px;
		width: 70px;
		flex-direction: column;
		justify-content: center;

		>div {
			flex-shrink: 0;
		}

		@media ( min-width: 899px ) {
			display: flex;
			padding: 8px 0 8px 8px;
		}

		@media ( min-width: 999px ) {
			padding: 8px 0 8px 16px;
			flex: 0 0 120px;
			width: 120px;
		}

		@media ( min-width: 1099px ) {
			flex: 0 0 160px;
			width: 160px;
		}
	}
}
